{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-guard.sh",
            "statusMessage": "Checking command safety..."
          },
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "~/.claude/hooks/require-code-review.sh",
            "statusMessage": "Checking code review..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
